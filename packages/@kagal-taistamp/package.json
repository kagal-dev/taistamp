{
  "name": "@kagal/taistamp",
  "version": "0.2.0",
  "type": "module",
  "description": "Signed TAI64N timestamps over HTTP",
  "author": "Apptly Software Ltd <oss@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/kagal-dev/taistamp/tree/main/packages/@kagal-taistamp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kagal-dev/taistamp.git",
    "directory": "packages/@kagal-taistamp"
  },
  "bugs": {
    "url": "https://github.com/kagal-dev/taistamp/issues"
  },
  "keywords": [
    "kagal",
    "cryptography",
    "ed25519",
    "eddsa",
    "handler",
    "http",
    "nonce",
    "rfc8032",
    "signing",
    "tai64n",
    "taistamp",
    "timestamp",
    "typescript",
    "webcrypto"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "default": "./dist/utils.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest",
    "dev:prepare": "obuild --stub",
    "lint": "eslint --fix .",
    "lint:_pkg-pr-new": "eslint --fix package.json",
    "lint:check": "eslint .",
    "precommit": "run-s dev:prepare lint type-check build test test:compat",
    "prepack": "run-s lint:_pkg-pr-new build lint:check type-check test publint",
    "prepare": "cross-test -s dist/index.mjs -a -s dist/utils.mjs || obuild --stub",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "test:compat": "node src/__tests__/compat.mjs",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "run-s type-check:main type-check:tools type-check:tests",
    "type-check:main": "tsc --noEmit -p tsconfig.json",
    "type-check:tests": "tsc --noEmit -p tsconfig.tests.json",
    "type-check:tools": "tsc --noEmit -p tsconfig.tools.json"
  },
  "dependencies": {
    "@kagal/ed25519-secret": "workspace:^"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260514.1",
    "@kagal/build-tsdoc": "^0.2.1",
    "@kagal/cross-test": "^0.1.3",
    "@noble/ed25519": "^3.1.0",
    "@poupe/eslint-config": "^0.10.1",
    "@types/node": "^20.19.41",
    "@vitest/coverage-istanbul": "^4.1.9",
    "eslint": "^10.5.0",
    "npm-run-all2": "^9.0.2",
    "obuild": "^0.4.37",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">= 20.20.1",
    "pnpm": ">= 10.33.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
