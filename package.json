{
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Signed TAI64N timestamps over HTTP",
  "author": "Apptly Software Ltd <oss@apptly.co>",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rimraf node_modules",
    "cspell": "cspell --config internal/build/cspell.json --gitignore --no-progress '**'",
    "dev:prepare": "pnpm -r dev:prepare",
    "lint": "run-s lint:root cspell lint:_packages",
    "lint:_packages": "pnpm -r lint",
    "lint:check": "run-s lint:root:check cspell lint:check:_packages",
    "lint:check:_packages": "pnpm -r lint:check",
    "lint:root": "eslint --fix --ignore-pattern 'packages/*' .",
    "lint:root:check": "eslint --ignore-pattern 'packages/*' .",
    "precommit": "run-s dev:prepare lint type-check build test test:compat",
    "prepack": "run-s lint:root:check prepack:_packages",
    "prepack:_packages": "pnpm -r prepack",
    "test": "pnpm -r test",
    "test:compat": "pnpm -r test:compat",
    "test:coverage": "pnpm -r test:coverage",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@poupe/eslint-config": "^0.10.1",
    "cspell": "^10.0.1",
    "eslint": "^10.6.0",
    "npm-run-all2": "^9.0.2",
    "pkg-pr-new": "~0.0.78",
    "rimraf": "^6.1.3"
  },
  "engines": {
    "node": ">= 20.20.1",
    "pnpm": ">= 10.34.5"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/utils": "8.62.1"
    }
  },
  "packageManager": "pnpm@10.34.5+sha512.a4ee05f2f73658255bd6a89859c065a45c28a57daefae2c893a168ee2b73168c37b91e83e57ea67654ad03f03031746430e8bce38e362e042605fb8abc80192e"
}
